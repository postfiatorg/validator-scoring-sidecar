POSTFIAT_SCORING_BASE_URL=https://scoring-devnet.postfiat.org
POSTFIAT_SIDECAR_DATA_DIR=~/.postfiat/validator-scoring-sidecar/devnet
POSTFIAT_SIDECAR_IPFS_GATEWAY_URL=https://ipfs-testnet.postfiat.org/ipfs
POSTFIAT_SIDECAR_NETWORK=devnet
POSTFIAT_SIDECAR_TIMEOUT_SECONDS=30
# Sync cadence for the docker compose deployment (positive integer, seconds).
# Has no effect when running the CLI outside Docker.
# POSTFIAT_SIDECAR_SYNC_INTERVAL_SECONDS=3600

# --- Participation mode (opt-in) ---
# Runs the on-chain commit-reveal loop instead of verify-only sync. Deploy with
# the participation overlay and uncomment the three required values below; the loop
# fails fast and changes nothing on chain if any prerequisite is missing:
#   docker compose -f docker-compose.yml -f docker-compose.participate.yml up -d
# POSTFIAT_SIDECAR_MODE=participate
# POSTFIAT_SIDECAR_VALIDATOR_WALLET_SEED=    # funded operator relay r... wallet: an s... seed or a 24-word Task Node recovery phrase (secret)
# POSTFIAT_SIDECAR_VALIDATOR_KEYS_FILE=      # host path of your validator-keys.json, mounted read-only
# Optional overrides; defaults are derived from the network.
# POSTFIAT_SIDECAR_PFTL_RPC_URL=https://rpc.devnet.postfiat.org
# POSTFIAT_SIDECAR_FOUNDATION_PUBLISHER_ADDRESS=
# POSTFIAT_SIDECAR_CHAIN_POLL_INTERVAL_SECONDS=60

# --- Liveness tuning (advanced, optional) ---
# Upper bound on one inference request's read timeout (seconds, default 180).
# The commit-deadline cap always takes precedence and shortens it near a round's
# commit close. Raise it only for a slower self-hosted SGLang runtime.
# POSTFIAT_SIDECAR_INFERENCE_TIMEOUT_SECONDS=180
# Per-pass watchdog for the docker compose loop (seconds). Defaults: sync 900;
# participate is derived to contain a full inference (inference timeout + 180,
# floor 360). If set explicitly for participate it must exceed the inference
# timeout plus 60s of head-room, or the container fails fast at startup.
# POSTFIAT_SIDECAR_COMMAND_TIMEOUT_SECONDS=

# Inference runtime for participation scoring — pick ONE of the two:
# Modal (zero-touch): set all four and the sidecar deploys and maintains the
# manifest-pinned Modal endpoint itself. Token = Modal account credentials,
# key/secret = the endpoint's proxy-auth credentials. All secret.
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
# POSTFIAT_SIDECAR_MODAL_KEY=
# POSTFIAT_SIDECAR_MODAL_SECRET=
# Optional: set a UNIQUE Modal app name per validator when several validators
# share one Modal account (defaults to validator-scoring-sidecar-devnet). Each
# validator also needs its own funded relay wallet seed above.
# POSTFIAT_SIDECAR_MODAL_APP_NAME=validator-scoring-sidecar-devnet-<validator>
# Optional: idle minutes Modal keeps the GPU (and its billing) alive after a
# request. Default 5 covers a same-round retry without a fresh cold start;
# raising it costs roughly one GPU-hour-fraction per round of pure idle.
# Accepts 1-20 (Modal caps the window at 20 minutes). A changed value
# applies at the next deploy of the Modal app.
# POSTFIAT_SIDECAR_MODAL_SCALEDOWN_MINUTES=5
# Local SGLang (self-hosted): start it with `start-sglang` on the GPU host
# and point the container at it (localhost is NOT reachable from the container;
# use host.docker.internal for a runtime on this host).
# POSTFIAT_SIDECAR_LOCAL_ENDPOINT_URL=http://host.docker.internal:8000/v1
# Optional (Modal mode): Hugging Face token for authenticated, unthrottled
# model weight downloads on first deploy - a read-only token is enough. Secret.
# For local SGLang, export HF_TOKEN in the GPU-host shell that runs
# start-sglang instead; this file never reaches that process.
# HF_TOKEN=
